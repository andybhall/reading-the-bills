# raw data is large and re-downloadable via Code/00_download_data.py;
# the manifest (sources, hashes, access dates) IS tracked
Original Data/voteview/*.csv
Original Data/voteview_prospective/*.csv
Original Data/govinfo/billstatus/

# regenerated by the pipeline; results/ and checks/ ARE tracked
Modified Data/*.parquet
Modified Data/splits/*.parquet
Modified Data/results/preds/*.parquet

# frozen artifacts are too large for git; their sha256 (tracked in the
# adjacent meta JSONs) is the integrity record
Modified Data/results/frozen/*.pkl

# published papers — copyright; a citation list lives in the draft
Literature/*.pdf

__pycache__/
.DS_Store

# secrets — never commit
.env
